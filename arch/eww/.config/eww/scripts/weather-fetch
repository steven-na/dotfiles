#!/usr/bin/env bash
# scripts/weather-fetch

loc_file="$HOME/.config/eww/.weather-location"
loc=$(cat "$loc_file" 2>/dev/null | xargs | sed 's/ /%20/g')
url="wttr.in/${loc}?format=j1"              # empty loc βÜ£ wttr.in/?format=j1 βÜ£ IP fallback

data=$(curl -sf "$url")
[[ -z "$data" ]] && echo "?¬ΑF" && exit 1

temp=$(echo "$data" | jq -r '.current_condition[0].temp_F')
code=$(echo "$data" | jq -r '.current_condition[0].weatherCode')

case "$code" in
  113)                                     icon="σΑ•ô" ;;
  116)                                     icon="σΑ•ï" ;;
  119|122)                                 icon="σΑ•ê" ;;
  143|248|260)                             icon="σΑ•ë" ;;
  200|386|389|392|395)                     icon="σΑ•™" ;;
  227|230|323|326|329|332|335|338|368|371) icon="σΑ•‰" ;;
  182|185|281|284|311|314|317|320|350|362|365|374|377) icon="σΑ•£" ;;
  *)                                       icon="σΑ•½" ;;
esac

sign=$([ "$temp" -ge 0 ] && echo "+" || echo "")
echo "${sign}${temp}¬ΑF ${icon}"
