#!/usr/bin/env bash
# scripts/weather-fetch

loc_file="$HOME/.config/eww/.weather-location"
loc=$(cat "$loc_file" 2>/dev/null | xargs | sed 's/ /%20/g')
url="wttr.in/${loc}?format=j1"

data=$(curl -sf "$url")
[[ -z "$data" ]] && echo "?В°F" && exit 1

temp=$(echo "$data" | jq -r '.current_condition[0].temp_F')
code=$(echo "$data" | jq -r '.current_condition[0].weatherCode')

# в”Җв”Җ Night check в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
sunrise_raw=$(echo "$data" | jq -r '.weather[0].astronomy[0].sunrise')
sunset_raw=$(echo  "$data" | jq -r '.weather[0].astronomy[0].sunset')

sunrise_epoch=$(date -d "today $sunrise_raw" +%s)
sunset_epoch=$(date -d  "today $sunset_raw"  +%s)
now_epoch=$(date +%s)

is_night=false
[[ $now_epoch -ge $sunset_epoch || $now_epoch -lt $sunrise_epoch ]] && is_night=true
# в”Җв”Җ Moon phase в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
moon_icon() {
  local ref; ref=$(date -d "2000-01-06" +%s)  # known new moon
  local days=$(( ($(date +%s) - ref) / 86400 ))
  local phase=$(( days % 29 ))
  if   [[ $phase -le 1  ]]; then echo "у°ҪӨ"  # new
  elif [[ $phase -le 7  ]]; then echo "у°Ҫ§"  # waxing crescent
  elif [[ $phase -le 8  ]]; then echo "у°ҪЎ"  # first quarter
  elif [[ $phase -le 14 ]]; then echo "у°ҪЁ"  # waxing gibbous
  elif [[ $phase -le 15 ]]; then echo "у°Ҫў"  # full
  elif [[ $phase -le 21 ]]; then echo "у°ҪҰ"  # waning gibbous
  elif [[ $phase -le 22 ]]; then echo "у°ҪЈ"  # last quarter
  else                            echo "у°ҪҘ"  # waning crescent
  fi
}

# в”Җв”Җ Icon selection в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if $is_night; then
  case "$code" in
    113)                                               icon=$(moon_icon) ;;  # clear вҶ’ moon phase
    116)                                               icon="оҲҰ" ;;           # nf-fa-cloud_moon
    119|122)                                           icon="оҢҪ" ;;           # overcast (no moon visible)
    143|248|260)                                       icon="оҚҶ" ;;           # fog/mist
    200|386|389|392|395)                               icon="оҢё" ;;           # nf-fa-cloud_moon_rain (thunder)
    227|230|323|326|329|332|335|338|368|371)           icon="оҢҡ" ;;           # snow (no night variant needed)
    182|185|281|284|311|314|317|320|350|362|365|374|377) icon="оҺ«" ;;         # nf-fa-cloud_moon_rain (sleet)
    *)                                                 icon="оҢі" ;;           # nf-fa-cloud_moon_rain (rain)
  esac
else
  case "$code" in
    113)                                               icon="у°–ҷ" ;;
    116)                                               icon="у°–•" ;;
    119|122)                                           icon="у°–җ" ;;
    143|248|260)                                       icon="оҢ“" ;;
    200|386|389|392|395)                               icon="оҢқ" ;;
    227|230|323|326|329|332|335|338|368|371)           icon="оҢҡ" ;;
    182|185|281|284|311|314|317|320|350|362|365|374|377) icon="оҺӯ" ;;
    *)                                                 icon="оҢҳ" ;;
  esac
fi

sign=$([ "$temp" -ge 0 ] && echo "+" || echo "")
echo "${sign}${temp}В°F ${icon}"
