# ── Config editing shortcuts ──────────────────────────────────────────────────
set -l dots ~/dotfiles/arch

alias envim  "nvim $dots/nvim/.config/nvim/"
alias etmux  "nvim $dots/tmux/.config/tmux/tmux.conf"
alias ehypr  "nvim $dots/hyprland/.config/hypr/"
alias efish  "nvim $dots/fish/.config/fish/config.fish"
alias eghostty "nvim $dots/ghostty/.config/ghostty/config"
alias ewwconf  "nvim $dots/eww/.config/eww/"
alias emako  "nvim $dots/mako/.config/mako/config"
alias ewallust "nvim $dots/wallust/.config/wallust/"
alias edots  "nvim $dots/"
